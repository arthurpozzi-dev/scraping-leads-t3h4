# Copie para .env e preencha. O .env real fica fora do git (ver .gitignore).

# Chave da PageSpeed Insights API (Google) usada como padrão de enriquecimento.
# Gere em: https://developers.google.com/speed/docs/insights/v5/get-started
PAGESPEED_API_KEY=

# Porta do servidor (opcional, padrão 3000).
PORT=3000

# Link do botão "Ver a versão reconstruída" no relatório de auditoria.
REPORT_CTA_URL=https://t3h4.com.br

# Análises de site (PageSpeed) em paralelo no enriquecimento. Padrão 8.
# Pode ser sobreposto pelo campo "Análises em paralelo" da interface.
ENRICH_CONCURRENCY=8

# Sites visitados em paralelo ao puxar o texto (botão "Puxar texto dos sites"). Padrão 8.
SITETEXT_CONCURRENCY=8

# (Linux) Caminho do Chromium do sistema. Opcional: se vazio, a ferramenta
# detecta automaticamente (/usr/bin/chromium-browser, /usr/bin/chromium, etc.).
# No Windows isso é ignorado — usa o Chromium do Playwright.
# CHROMIUM_PATH=/usr/bin/chromium-browser
